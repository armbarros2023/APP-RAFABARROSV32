# ============================================
# VARIÁVEIS DE AMBIENTE - TELEFLIX/CLINICFLOW
# ============================================
# 
# INSTRUÇÕES:
# 1. Copie este arquivo para .env.local
# 2. Preencha os valores reais
# 3. NUNCA commite o arquivo .env.local
#
# ============================================

# API Key do Google Gemini AI
# Obtenha em: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=sua_chave_api_aqui

# Alternativa (Vite usa VITE_ prefix)
VITE_API_KEY=sua_chave_api_aqui

# ============================================
# CONFIGURAÇÕES DO BACKEND (Quando implementado)
# ============================================

# URL da API Backend
# Desenvolvimento: http://localhost:5000
# Produção: https://api.seudominio.com
# VITE_API_URL=http://localhost:5000

# Chave secreta para JWT (gerar com: openssl rand -base64 32)
# JWT_SECRET=

# URL do Banco de Dados
# DATABASE_URL=postgresql://user:password@localhost:5432/clinicflow

# Ambiente (development, staging, production)
# NODE_ENV=development

# ============================================
# CONFIGURAÇÕES DE EMAIL (Futuro)
# ============================================

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seu_email@gmail.com
# SMTP_PASS=sua_senha_app

# ============================================
# CONFIGURAÇÕES DE ARMAZENAMENTO (Futuro)
# ============================================

# AWS S3 ou similar para upload de arquivos
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_BUCKET_NAME=
# AWS_REGION=us-east-1

# ============================================
# OBSERVAÇÕES DE SEGURANÇA
# ============================================
#
# ⚠️ IMPORTANTE:
# - Nunca compartilhe este arquivo com valores reais
# - Use diferentes chaves para dev/staging/production
# - Rotacione chaves periodicamente
# - Use secrets managers em produção (AWS Secrets, etc)
#
# ============================================
